# Aya POS — Environment Variables Template
# 1. Copy this file to .env.local
# 2. Fill in your real values
# 3. Never commit .env.local

# Supabase Project URL
# Found at: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Anon Public Key (safe for client-side code)
# Found at: Supabase Dashboard → Project Settings → API → Project API Keys
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY_HERE
